[Unit]
Description=Kite Window Finder FastAPI service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/kite_window_finder
EnvironmentFile=/opt/kite_window_finder/.env
ExecStart=/opt/kite_window_finder/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
